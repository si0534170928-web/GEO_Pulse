{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    
    /* הגדרות קריטיות לפתרון השגיאה */
    "composite": true,        // מאפשר לפרויקטים אחרים להסתמך עליו
    "noEmit": false,          // TypeScript חייב רשות לייצר קבצי מידע זמניים
    "declaration": true,      // נדרש יחד עם composite
    "declarationMap": true,   // עוזר לדיבאג
    
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}